{
  "name": "medaction",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "load:quick": "artillery run tests/load/quick-test.yml",
    "load:full": "artillery run tests/load/artillery.yml",
    "load:report": "artillery run tests/load/artillery.yml --output report.json && artillery report report.json",
    "clean": "rm -rf .next coverage test-results playwright-report .swc tsconfig.tsbuildinfo",
    "clean:all": "npm run clean && rm -rf node_modules",
    "fresh": "npm run clean:all && npm install",
    "analyze": "npx depcheck",
    "db:migrate": "npx prisma migrate deploy",
    "db:push": "npx prisma db push",
    "db:studio": "npx prisma studio",
    "db:seed": "npx prisma db seed",
    "seed:permissions": "tsx prisma/seed-permissions.ts",
    "docker:build": "docker build -t medaction:latest .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f app",
    "postinstall": "npx prisma generate",
    "i18n:extract": "tsx scripts/i18n/extract-keys.ts",
    "i18n:validate": "tsx scripts/i18n/validate-translations.ts",
    "i18n:sync": "tsx scripts/i18n/sync-locales.ts",
    "i18n:translate": "tsx scripts/i18n/translate-missing.ts",
    "maintenance:backup": "tsx scripts/backup.ts",
    "maintenance:clear": "tsx scripts/clear-tables.ts",
    "maintenance:restore": "tsx scripts/restore.ts"
  },
  "dependencies": {
    "@formatjs/intl-localematcher": "^0.7.5",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^5.22.0",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/nextjs": "^10.51.0",
    "@types/dompurify": "^3.0.5",
    "@types/leaflet": "^1.9.21",
    "@types/mapbox-gl": "^3.4.1",
    "@types/negotiator": "^0.6.4",
    "@types/qrcode": "^1.5.6",
    "@upstash/redis": "^1.37.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.2",
    "exceljs": "^4.4.0",
    "follow-redirects": "^1.16.0",
    "framer-motion": "^12.38.0",
    "glob": "^13.0.6",
    "handlebars": "^4.7.9",
    "ioredis": "^5.10.1",
    "leaflet": "^1.9.4",
    "lodash": "^4.18.1",
    "lucide-react": "^0.556.0",
    "mapbox-gl": "^3.23.0",
    "negotiator": "^1.0.0",
    "next": "^15.5.15",
    "next-auth": "^4.24.14",
    "next-intl": "4.9.1",
    "next-themes": "^0.4.6",
    "otplib": "^12.0.1",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.74.0",
    "react-leaflet": "^4.2.1",
    "recharts": "^3.8.1",
    "rollup": "^4.60.2",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwindcss-animate": "^1.0.7",
    "undici": "^6.25.0",
    "use-debounce": "^10.1.1",
    "uuid": "^13.0.1",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.39",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "axios": "^1.15.2",
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "cli-table3": "^0.6.5",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "figlet": "^1.11.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "ora": "^9.4.0",
    "postcss": "^8.5.13",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "seed": "node --loader ts-node/esm prisma/seed-real-data.ts"
  }
}
